{
  "manifest_version": 3,
  "name": "Prime Auto-Skip",
  "version": "1.2.0",
  "description": "Automatically clicks Skip Intro, Skip Credits, and Skip Recap buttons on Amazon Prime Video.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.primevideo.com/*",
    "*://*.amazon.com/gp/video/*",
    "*://*.amazon.co.uk/gp/video/*",
    "*://*.amazon.de/gp/video/*",
    "*://*.amazon.fr/gp/video/*",
    "*://*.amazon.co.jp/gp/video/*",
    "*://*.amazon.ca/gp/video/*",
    "*://*.amazon.com.au/gp/video/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.primevideo.com/*",
        "*://*.amazon.com/gp/video/*",
        "*://*.amazon.co.uk/gp/video/*",
        "*://*.amazon.de/gp/video/*",
        "*://*.amazon.fr/gp/video/*",
        "*://*.amazon.co.jp/gp/video/*",
        "*://*.amazon.ca/gp/video/*",
        "*://*.amazon.com.au/gp/video/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
